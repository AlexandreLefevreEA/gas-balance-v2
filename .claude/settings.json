{
  "permissions": {
    "deny": [
      "Read(./**/.venv/**)",
      "Read(./**/venv/**)",
      "Read(./**/node_modules/**)",
      "Read(./**/__pycache__/**)",
      "Read(./**/mlruns/**)",
      "Read(./**/data/**)",
      "Write(./legacy/**)",
      "Edit(./legacy/**)",
      "NotebookEdit(./legacy/**)"
    ],
    "allow": [
      "Bash(uv run pytest:*)",
      "Bash(uv run ruff:*)",
      "Bash(uv run mypy:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)"
    ]
  }
}
