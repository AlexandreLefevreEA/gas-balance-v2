# --- Secrets / env ---
.env
.env.*
!.env.example

# --- Legacy v1: contains plaintext secrets; excluded from VCS until scrubbed + rotated.
#     Keep only its CLAUDE.md so the repo documents why it's excluded.
/legacy/*
!/legacy/CLAUDE.md

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
.uv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/
.ipynb_checkpoints/

# --- Data / artifacts (trusted data lives in Postgres, not git) ---
data/
*.pkl
*.parquet
*.xlsx
*.xls
*.csv
!**/fixtures/**/*.csv

# --- ML experiment tracking ---
mlruns/
mlartifacts/
optuna.db
*.optuna

# --- Node / web ---
node_modules/
web/dist/
.vite/
*.local

# --- Claude Code local settings (personal, per-machine; may grant permissions) ---
.claude/settings.local.json
# Worktree-guard runtime locks (one per live session; see .claude/hooks/worktree-lib.ps1)
.claude/locks/
# Per-agent git worktrees (whole nested checkouts) + scheduler lock — local, never committed
.claude/worktrees/
.claude/scheduled_tasks.lock

# --- Editors / OS ---
.idea/
.vscode/
.DS_Store
Thumbs.db
