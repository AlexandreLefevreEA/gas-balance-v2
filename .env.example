# Copy to .env and fill in. NEVER commit .env. These are NAMES only — no real values.

# --- Environment selector ---
# local | prod. Guards destructive ops; non-local DB hosts require APP_ENV=prod.
APP_ENV=local

# --- Postgres (single source of truth for the connection) ---
# Local dev points at localhost. Prod injects its own DATABASE_URL via real env
# vars / secrets — do NOT keep the prod URL in this dev file (not even commented).
DATABASE_URL=postgresql+psycopg://postgres:PASSWORD@localhost:5432/postgres
# All objects live in this schema:
DB_SCHEMA=gas_balance

# --- Data-source credentials ---
# One block per source; declare secret NAMES here (no real values).

# Commodity Essentials (HTTP Basic Auth). Get creds from the CE portal.
CE_USERNAME=
CE_PASSWORD=
CE_BASE_URL=https://commodityessentials.com/api/   # trailing slash; default if unset

# Kpler (power/weather: temperatures, generation, demand, prices/emissions, gas forward). HTTP Basic
# auth with a base64 'id:secret' API key, sent verbatim. Shared by every kpler_* connector.
KPLER_API_KEY_V2=
KPLER_BASE_URL=https://api.kpler.com/v2   # default if unset

# ECB euro FX reference rates (ecb_fx). PUBLIC, no credentials — `fetch()` downloads
# https://www.ecb.europa.eu/stats/eurofxref/eurofxref-hist.zip directly. No env vars needed.

# Energy Quantified / Montel EQ (OHLC commodity curves: eq_coal_curve, eq_coal_spot). Sent as
# the `X-API-Key` request header (not Basic). Shared by every eq_* connector.
EQ_API_KEY=
EQ_BASE_URL=https://app.energyquantified.com/api   # default if unset (note `app.`, not `api.`)

# --- ML experiment tracking ---
MLFLOW_TRACKING_URI=file:./ml/experiments/mlruns

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
# Comma-separated browser origins allowed by CORS (the web dev server):
API_CORS_ORIGINS=http://localhost:5173

# --- Web (Vite only exposes vars prefixed with VITE_ to the browser) ---
VITE_API_BASE_URL=http://localhost:8000
