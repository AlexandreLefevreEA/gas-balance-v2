# Copy to .env and fill in. NEVER commit .env. These are NAMES only — no real values.

# --- Environment selector ---
# local | prod. Guards destructive ops; non-local DB hosts require APP_ENV=prod.
APP_ENV=local

# --- Postgres (single source of truth for the connection) ---
# Local dev points at localhost. Prod injects its own DATABASE_URL via real env
# vars / secrets — do NOT keep the prod URL in this dev file (not even commented).
DATABASE_URL=postgresql+psycopg://postgres:PASSWORD@localhost:5432/postgres
# All objects live in this schema:
DB_SCHEMA=gas_balance

# --- Data-source credentials ---
# One block per source; declare secret NAMES here (no real values).

# Commodity Essentials (HTTP Basic Auth). Get creds from the CE portal.
CE_USERNAME=
CE_PASSWORD=
CE_BASE_URL=https://commodityessentials.com/api/   # trailing slash; default if unset

# --- ML experiment tracking ---
MLFLOW_TRACKING_URI=file:./ml/experiments/mlruns

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Web (Vite only exposes vars prefixed with VITE_ to the browser) ---
VITE_API_BASE_URL=http://localhost:8000
