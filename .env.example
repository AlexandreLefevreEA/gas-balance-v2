# Copy to .env and fill in. NEVER commit .env. These are NAMES only — no real values.

# --- Postgres (trusted data store; reuse the existing v1 power DB) ---
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/gas_balance
# Discrete vars if preferred over a single URL:
DB_HOST=
DB_PORT=5432
DB_NAME=gas_balance
DB_USER=
DB_PASSWORD=

# --- Data-source credentials ---
# Sources are not chosen yet. When you add a connector, declare its secret NAMES
# here (one block per source), e.g.:
# <SOURCE>_API_KEY=
# <SOURCE>_USERNAME=
# <SOURCE>_PASSWORD=

# --- ML experiment tracking ---
MLFLOW_TRACKING_URI=file:./ml/experiments/mlruns

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Web (Vite only exposes vars prefixed with VITE_ to the browser) ---
VITE_API_BASE_URL=http://localhost:8000
